# Microservice IA (FastAPI) — voir ia/api.py
IA_ENABLED=true
IA_SERVICE_URL=http://127.0.0.1:8000
IA_LOOKBACK_HOURS=48
IA_REQUEST_TIMEOUT_MS=30000
# Heures agrégées minimum pour LSTM (défaut ~43 = 90% de 48h). Mettre 4 pour tests avec simulateur récent.
# IA_MIN_FILLED_HOURS=4
# IA_SKILL_REPORT_PATH=../ia/models/lstm_4h_skill_report.json

# Alertes MongoDB sur dépassement prévu (optionnel, défaut false)
IA_CREATE_FORECAST_ALERTS=false

# Isolation Forest (défaut activé si IA_ENABLED=true)
IA_IF_ENABLED=true
IA_IF_MIN_FEATURES=4
# Alertes type Anomaly quand IF signale un profil atypique (défaut true)
IA_CREATE_ANOMALY_ALERTS=true
